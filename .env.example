# Free keys — each takes about a minute:
#   NREL:   https://developer.nlr.gov/signup/   (DEMO_KEY works for light testing)
#   OpenEI: https://openei.org/services/api/signup/
#   EIA:    https://www.eia.gov/opendata/register.php
NREL_API_KEY=
OPENEI_API_KEY=
EIA_API_KEY=

# Optional: SunSpec AHJ Registry token (email support@sunspec.org)
AHJ_REGISTRY_TOKEN=

# Optional: set to 1 to log requests/cache activity to stderr
SOLAR_DATA_MCP_DEBUG=

# Optional: override the cache directory (default ~/.cache/solar-data-mcp)
SOLAR_DATA_MCP_CACHE_DIR=
